{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "WMD: Launch Side Preview",
      "dependsOrder": "sequence",
      "dependsOn": [
        "WMD: Dev Server",
        "WMD: Open Side Preview"
      ],
      "problemMatcher": []
    },
    {
      "label": "WMD: Build",
      "type": "process",
      "command": "node",
      "args": [
        "./wmd-compiler.js",
        "${file}",
        "${fileDirname}\\${fileBasenameNoExtension}.html"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": {
        "owner": "wmd",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": {
          "regexp": "^(error|warning)\\s+(.+?):\\s+(.*)$",
          "severity": 1,
          "file": 2,
          "message": 3
        }
      }
    },
    {
      "label": "WMD: Watch",
      "type": "process",
      "command": "node",
      "args": [
        "./wmd-compiler.js",
        "--watch",
        "${file}",
        "${fileDirname}\\${fileBasenameNoExtension}.html"
      ],
      "isBackground": true,
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      },
      "problemMatcher": {
        "owner": "wmd",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": {
          "regexp": "^(error|warning)\\s+(.+?):\\s+(.*)$",
          "severity": 1,
          "file": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^",
          "endsPattern": "^Watching\\s+"
        }
      }
    },
    {
      "label": "WMD: Open Side Preview",
      "type": "process",
      "command": "code.cmd",
      "args": [
        "--reuse-window",
        "http://127.0.0.1:4312"
      ],
      "presentation": {
        "reveal": "never",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "WMD: Dev Server",
      "type": "process",
      "command": "node",
      "args": [
        "./wmd-compiler.js",
        "--serve",
        "--watch",
        "${file}",
        "${fileDirname}\\${fileBasenameNoExtension}.html"
      ],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": {
        "owner": "wmd",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": {
          "regexp": "^(error|warning)\\s+(.+?):\\s+(.*)$",
          "severity": 1,
          "file": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^",
          "endsPattern": "^Watching\\s+"
        }
      }
    }
  ]
}
