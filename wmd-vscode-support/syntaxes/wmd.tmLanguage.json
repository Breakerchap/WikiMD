{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Wiki Markdown",
  "scopeName": "text.wmd",
  "patterns": [
    {
      "include": "#config-block"
    },
    {
      "include": "#code-fences"
    },
    {
      "include": "#wmd-callout-blocks"
    },
    {
      "include": "#wmd-collapse-blocks"
    },
    {
      "include": "#wmd-directives"
    },
    {
      "include": "#headings"
    },
    {
      "include": "#wiki-links"
    },
    {
      "include": "#standard-links"
    },
    {
      "include": "#variable-references"
    },
    {
      "include": "#inline-code"
    },
    {
      "include": "#highlight-red"
    },
    {
      "include": "#highlight-orange"
    },
    {
      "include": "#highlight-yellow"
    },
    {
      "include": "#bold"
    },
    {
      "include": "#italic"
    },
    {
      "include": "#lists"
    },
    {
      "include": "#blockquote"
    },
    {
      "include": "#horizontal-rule"
    }
  ],
  "repository": {
    "config-block": {
      "name": "meta.config.wmd",
      "begin": "^(@config)\\s*$",
      "beginCaptures": {
        "1": {
          "name": "keyword.control.directive.config.begin.wmd"
        }
      },
      "end": "^(@endconfig)\\s*$",
      "endCaptures": {
        "1": {
          "name": "keyword.control.directive.config.end.wmd"
        }
      },
      "patterns": [
        {
          "name": "meta.config.style-preset.wmd",
          "begin": "^\\s*([^:\\n]+?)(\\s*:\\s*)(\\{)",
          "beginCaptures": {
            "1": {
              "name": "entity.name.section.style-preset.wmd"
            },
            "2": {
              "name": "punctuation.separator.key-value.wmd"
            },
            "3": {
              "name": "punctuation.section.braces.begin.wmd"
            }
          },
          "end": "(\\})(;)?\\s*$",
          "endCaptures": {
            "1": {
              "name": "punctuation.section.braces.end.wmd"
            },
            "2": {
              "name": "punctuation.terminator.statement.wmd"
            }
          },
          "patterns": [
            {
              "match": "([A-Za-z][\\w-]*)(\\s*:\\s*)([^;]+)(;?)",
              "captures": {
                "1": {
                  "name": "support.type.property-name.style.wmd"
                },
                "2": {
                  "name": "punctuation.separator.key-value.wmd"
                },
                "3": {
                  "name": "string.unquoted.style-value.wmd"
                },
                "4": {
                  "name": "punctuation.terminator.statement.wmd"
                }
              }
            }
          ]
        },
        {
          "match": "^\\s*([A-Za-z][A-Za-z0-9_-]*)\\s*(:)\\s*(.*?)\\s*(;)?$",
          "captures": {
            "1": {
              "name": "support.type.property-name.wmd"
            },
            "2": {
              "name": "punctuation.separator.key-value.wmd"
            },
            "3": {
              "name": "string.unquoted.config-value.wmd"
            },
            "4": {
              "name": "punctuation.terminator.statement.wmd"
            }
          }
        }
      ]
    },
    "code-fences": {
      "patterns": [
        {
          "name": "markup.fenced_code.block.wmd",
          "begin": "^\\s*(```)([A-Za-z0-9_-]+)?\\s*$",
          "beginCaptures": {
            "1": {
              "name": "punctuation.definition.code-fence.begin.wmd"
            },
            "2": {
              "name": "entity.name.type.language.wmd"
            }
          },
          "end": "^\\s*(```)\\s*$",
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.code-fence.end.wmd"
            }
          }
        }
      ]
    },
    "wmd-callout-blocks": {
      "patterns": [
        {
          "name": "meta.callout.wmd",
          "begin": "^\\s*(!(?:note|tip|info|warning|danger|rule|example))(?:\\s+(.+))?$",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.directive.callout.begin.wmd"
            },
            "2": {
              "name": "entity.name.section.callout-title.wmd"
            }
          },
          "end": "^\\s*(!end)\\s*$",
          "endCaptures": {
            "1": {
              "name": "keyword.control.directive.callout.end.wmd"
            }
          },
          "patterns": [
            {
              "include": "#wiki-links"
            },
            {
              "include": "#standard-links"
            },
            {
              "include": "#variable-references"
            },
            {
              "include": "#inline-code"
            },
            {
              "include": "#highlight-red"
            },
            {
              "include": "#highlight-orange"
            },
            {
              "include": "#highlight-yellow"
            },
            {
              "include": "#bold"
            },
            {
              "include": "#italic"
            }
          ]
        }
      ]
    },
    "wmd-collapse-blocks": {
      "patterns": [
        {
          "name": "meta.collapse.wmd",
          "begin": "^\\s*(@collapse)(?:\\s+(.+))?$",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.directive.collapse.begin.wmd"
            },
            "2": {
              "name": "entity.name.section.collapse-title.wmd"
            }
          },
          "end": "^\\s*(@endcollapse)\\s*$",
          "endCaptures": {
            "1": {
              "name": "keyword.control.directive.collapse.end.wmd"
            }
          },
          "patterns": [
            {
              "include": "#wiki-links"
            },
            {
              "include": "#standard-links"
            },
            {
              "include": "#variable-references"
            },
            {
              "include": "#inline-code"
            },
            {
              "include": "#highlight-red"
            },
            {
              "include": "#highlight-orange"
            },
            {
              "include": "#highlight-yellow"
            },
            {
              "include": "#bold"
            },
            {
              "include": "#italic"
            },
            {
              "include": "#lists"
            }
          ]
        }
      ]
    },
    "wmd-directives": {
      "patterns": [
        {
          "match": "^\\s*(@hidden)\\s*$",
          "captures": {
            "1": {
              "name": "keyword.control.directive.hidden.wmd"
            }
          }
        },
        {
          "match": "^\\s*(@tab)\\s+([^\\[{]+?)(\\s*(\\{hidden\\}|\\[hidden\\]))?\\s*$",
          "captures": {
            "1": {
              "name": "keyword.control.directive.tab.wmd"
            },
            "2": {
              "name": "entity.name.section.tab.wmd"
            },
            "4": {
              "name": "storage.modifier.hidden.wmd"
            }
          }
        },
        {
          "match": "^\\s*(@title)\\s+(.+)$",
          "captures": {
            "1": {
              "name": "keyword.control.directive.title.wmd"
            },
            "2": {
              "name": "entity.name.section.title.wmd"
            }
          }
        },
        {
          "match": "^\\s*(@(?:include|embed))\\s+([^#\\s]+)(#([^\\s]+))?\\s*$",
          "captures": {
            "1": {
              "name": "keyword.control.directive.include.wmd"
            },
            "2": {
              "name": "variable.other.tab-reference.wmd"
            },
            "3": {
              "name": "meta.heading-reference.wmd"
            },
            "4": {
              "name": "variable.other.heading-reference.wmd"
            }
          }
        },
        {
          "match": "^\\s*(@toc)(?:\\s+(depth)\\s*(:)\\s*([1-6]))?\\s*$",
          "captures": {
            "1": {
              "name": "keyword.control.directive.toc.wmd"
            },
            "2": {
              "name": "support.type.property-name.wmd"
            },
            "3": {
              "name": "punctuation.separator.key-value.wmd"
            },
            "4": {
              "name": "constant.numeric.depth.wmd"
            }
          }
        },
        {
          "match": "^\\s*(@var)\\s+([A-Za-z][\\w-]*)\\s*(=|:)\\s*(.+)$",
          "captures": {
            "1": {
              "name": "keyword.control.directive.var.wmd"
            },
            "2": {
              "name": "variable.other.constant.wmd"
            },
            "3": {
              "name": "punctuation.separator.key-value.wmd"
            },
            "4": {
              "name": "string.unquoted.variable-value.wmd"
            }
          }
        },
        {
          "match": "^\\s*(@style)\\s+(.+?)\\s*$",
          "captures": {
            "1": {
              "name": "keyword.control.directive.style.begin.wmd"
            },
            "2": {
              "name": "entity.name.section.style-preset.wmd"
            }
          }
        },
        {
          "match": "^\\s*(@end(?:style)?)\\s*$",
          "captures": {
            "1": {
              "name": "keyword.control.directive.style.end.wmd"
            }
          }
        }
      ]
    },
    "headings": {
      "patterns": [
        {
          "match": "^(#{1,6})\\s+(.+)$",
          "captures": {
            "1": {
              "name": "punctuation.definition.heading.wmd"
            },
            "2": {
              "name": "entity.name.section.heading.wmd"
            }
          }
        }
      ]
    },
    "wiki-links": {
      "patterns": [
        {
          "match": "(\\[\\[)([^\\]|#]+)(#([^\\]|]+))?(\\|([^\\]]+))?(\\]\\])",
          "captures": {
            "1": {
              "name": "punctuation.definition.link.wiki.begin.wmd"
            },
            "2": {
              "name": "variable.other.tab-reference.wmd"
            },
            "3": {
              "name": "meta.heading-reference.wmd"
            },
            "4": {
              "name": "variable.other.heading-reference.wmd"
            },
            "5": {
              "name": "punctuation.separator.link.label.wmd"
            },
            "6": {
              "name": "string.other.link-label.wmd"
            },
            "7": {
              "name": "punctuation.definition.link.wiki.end.wmd"
            }
          }
        }
      ]
    },
    "standard-links": {
      "patterns": [
        {
          "match": "(\\[)([^\\]]+)(\\])(\\()([^\\)]+)(\\))",
          "captures": {
            "1": {
              "name": "punctuation.definition.link.begin.wmd"
            },
            "2": {
              "name": "string.other.link-title.wmd"
            },
            "3": {
              "name": "punctuation.definition.link.end.wmd"
            },
            "4": {
              "name": "punctuation.definition.link-target.begin.wmd"
            },
            "5": {
              "name": "markup.underline.link.wmd"
            },
            "6": {
              "name": "punctuation.definition.link-target.end.wmd"
            }
          }
        }
      ]
    },
    "variable-references": {
      "patterns": [
        {
          "match": "(\\{\\{)([A-Za-z][\\w-]*)(\\}\\})",
          "captures": {
            "1": {
              "name": "punctuation.definition.variable.begin.wmd"
            },
            "2": {
              "name": "variable.other.constant.wmd"
            },
            "3": {
              "name": "punctuation.definition.variable.end.wmd"
            }
          }
        }
      ]
    },
    "inline-code": {
      "patterns": [
        {
          "match": "(`)([^`]+)(`)",
          "captures": {
            "1": {
              "name": "punctuation.definition.raw.begin.wmd"
            },
            "2": {
              "name": "markup.inline.raw.string.wmd"
            },
            "3": {
              "name": "punctuation.definition.raw.end.wmd"
            }
          }
        }
      ]
    },
    "highlight-red": {
      "patterns": [
        {
          "match": "(?<![=])(===)([^=\\n][\\s\\S]*?[^=\\n]|[^=\\n])(===)(?![=])",
          "captures": {
            "1": {
              "name": "punctuation.definition.highlight.red.begin.wmd"
            },
            "2": {
              "name": "markup.highlight.red.wmd"
            },
            "3": {
              "name": "punctuation.definition.highlight.red.end.wmd"
            }
          }
        }
      ]
    },
    "highlight-orange": {
      "patterns": [
        {
          "match": "(?<![=])(==)([^=\\n][\\s\\S]*?[^=\\n]|[^=\\n])(==)(?![=])",
          "captures": {
            "1": {
              "name": "punctuation.definition.highlight.orange.begin.wmd"
            },
            "2": {
              "name": "markup.highlight.orange.wmd"
            },
            "3": {
              "name": "punctuation.definition.highlight.orange.end.wmd"
            }
          }
        }
      ]
    },
    "highlight-yellow": {
      "patterns": [
        {
          "match": "(?<![=])(=)([^=\\n][\\s\\S]*?[^=\\n]|[^=\\n])(=)(?![=])",
          "captures": {
            "1": {
              "name": "punctuation.definition.highlight.yellow.begin.wmd"
            },
            "2": {
              "name": "markup.highlight.yellow.wmd"
            },
            "3": {
              "name": "punctuation.definition.highlight.yellow.end.wmd"
            }
          }
        }
      ]
    },
    "bold": {
      "patterns": [
        {
          "match": "(?<!\\*)(\\*)([^*\\n]+)(\\*)(?!\\*)",
          "captures": {
            "1": {
              "name": "punctuation.definition.bold.begin.wmd"
            },
            "2": {
              "name": "markup.bold.wmd"
            },
            "3": {
              "name": "punctuation.definition.bold.end.wmd"
            }
          }
        }
      ]
    },
    "italic": {
      "patterns": [
        {
          "match": "(?<!_)(_)([^_\\n]+)(_)(?!_)",
          "captures": {
            "1": {
              "name": "punctuation.definition.italic.begin.wmd"
            },
            "2": {
              "name": "markup.italic.wmd"
            },
            "3": {
              "name": "punctuation.definition.italic.end.wmd"
            }
          }
        }
      ]
    },
    "lists": {
      "patterns": [
        {
          "match": "^\\s*([-+*]|\\d+\\.)\\s+",
          "name": "punctuation.definition.list.begin.wmd"
        }
      ]
    },
    "blockquote": {
      "patterns": [
        {
          "match": "^\\s*>\\s?.*$",
          "name": "markup.quote.wmd"
        }
      ]
    },
    "horizontal-rule": {
      "patterns": [
        {
          "match": "^\\s*(-{3,}|_{3,}|\\*{3,})\\s*$",
          "name": "punctuation.definition.thematic-break.wmd"
        }
      ]
    }
  }
}
