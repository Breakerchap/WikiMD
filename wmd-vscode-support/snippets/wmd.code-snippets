{
  "New Tab": {
    "prefix": "@tab",
    "body": [
      "@tab ${1:Tab Name}",
      "@title ${2:Title}",
      "",
      "# ${3:Heading}",
      "",
      "$0"
    ],
    "description": "Create a new WMD tab with a title and first heading"
  },
  "Config Block": {
    "prefix": "@config",
    "body": [
      "@config",
      "font: ${1:Arial, sans-serif}",
      "monoFont: ${2:Consolas, monospace}",
      "baseSize: ${3:16px}",
      "titleSize: ${4:3rem}",
      "h1Size: ${5:2rem}",
      "h2Size: ${6:1.5rem}",
      "h3Size: ${7:1.25rem}",
      "lineHeight: ${8:1.6}",
      "contentWidth: ${9:900px}",
      "@endconfig",
      "",
      "$0"
    ],
    "description": "Insert a full WMD config block"
  },
  "Title": {
    "prefix": "@title",
    "body": "@title ${1:Title}",
    "description": "Insert a tab title"
  },
  "Wiki Link": {
    "prefix": "link",
    "body": "[[${1:Tab Name}${2:#Heading}|${3:Label}]]",
    "description": "Insert a WMD wiki link"
  },
  "Wiki Link Without Label": {
    "prefix": "[[",
    "body": "[[${1:Tab Name}${2:#Heading}]]",
    "description": "Insert a WMD wiki link without a label"
  },
  "Yellow Highlight": {
    "prefix": "=",
    "body": "=${1:yellow note}=",
    "description": "Yellow highlight"
  },
  "Orange Highlight": {
    "prefix": "==",
    "body": "==${1:important note}==",
    "description": "Light orange highlight"
  },
  "Red Highlight": {
    "prefix": "===",
    "body": "===${1:warning note}===",
    "description": "Light red highlight"
  },
  "Bold": {
    "prefix": "bold",
    "body": "*${1:bold text}*",
    "description": "Bold text"
  },
  "Italic": {
    "prefix": "italic",
    "body": "_${1:italic text}_",
    "description": "Italic text"
  },
  "Code Fence": {
    "prefix": "code",
    "body": [
      "```${1:js}",
      "$0",
      "```"
    ],
    "description": "Insert a fenced code block"
  },
  "Hidden Tab": {
    "prefix": "@hidden",
    "body": "@hidden",
    "description": "Mark the current WMD tab as hidden"
  },
  "Table of Contents": {
    "prefix": "@toc",
    "body": "@toc depth: ${1:3}",
    "description": "Insert a per-tab table of contents"
  },
  "Include": {
    "prefix": "@include",
    "body": "@include ${1:Tab Name}${2:#Heading}",
    "description": "Include another tab or heading section"
  },
  "Embed": {
    "prefix": "@embed",
    "body": "@embed ${1:Tab Name}${2:#Heading}",
    "description": "Embed another tab or heading section"
  },
  "Variable": {
    "prefix": "@var",
    "body": "@var ${1:name} = ${2:value}",
    "description": "Define a WMD variable"
  },
  "Variable Reference": {
    "prefix": "{{",
    "body": "{{${1:name}}}",
    "description": "Insert a WMD variable reference"
  },
  "Note Callout": {
    "prefix": "!note",
    "body": [
      "!note ${1:Title}",
      "${2:Content}",
      "!end"
    ],
    "description": "Insert a note callout"
  },
  "Warning Callout": {
    "prefix": "!warning",
    "body": [
      "!warning ${1:Title}",
      "${2:Content}",
      "!end"
    ],
    "description": "Insert a warning callout"
  },
  "Rule Callout": {
    "prefix": "!rule",
    "body": [
      "!rule ${1:Title}",
      "${2:Content}",
      "!end"
    ],
    "description": "Insert a rule callout"
  },
  "Example Callout": {
    "prefix": "!example",
    "body": [
      "!example ${1:Title}",
      "${2:Content}",
      "!end"
    ],
    "description": "Insert an example callout"
  },
  "Collapse": {
    "prefix": "@collapse",
    "body": [
      "@collapse ${1:Title}",
      "${2:Hidden content}",
      "@endcollapse"
    ],
    "description": "Insert a collapsible section"
  }
}